# -------------------------
# APP
# -------------------------
APP_NAME=SentinelAI
APP_ENV=development

# -------------------------
# JWT
# -------------------------
JWT_SECRET_KEY=super_secret_key_12345
JWT_REFRESH_SECRET_KEY=refresh_secret_67890
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------
# API KEYS
# -------------------------
CCTV_API_KEY=sentinel_cctv_key
EXAM_API_KEY=sentinel_exam_key
LMS_API_KEY=sentinel_lms_key

# -------------------------
# WEBSOCKET
# -------------------------
WS_SECRET_KEY=websocket_secret

# -------------------------
# CAMERA
# -------------------------
DEFAULT_CAMERA=0

# -------------------------
# LOGGING
# -------------------------
LOG_LEVEL=INFO
